{
  "layer": "top",
  "position": "top",
  "modules-left": [
    "custom/logout",
    "hyprland/workspaces",
    "custom/clipboard",
    "hyprland/language"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "network",
    "wireplumber",
    "temperature",
    "memory",
    "battery",
    "tray",
    "custom/notification"
  ],
  "clock": {
    "format": "󰥔 {:%H:%M | 󰃭 %d-%m-%Y}",
    "tooltip": false,
    "interval": 1
  },
  "custom/logout": {
    "format": "󰐥",
    "on-click": "wlogout",
    "tooltip": false
  },
  "temperature": {
    "thermal-zone": 0,
    "format": "󰔏 {temperatureC}°C",
    "interval": 1,
    "tooltip": false
  },
"memory": {
    "format": "󰍛 {used:0.1f}G",
    "interval": 1
  },
  "battery": {
    "format": "󰁹 {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-warning": "󰂃 {capacity}%",
    "format-critical": "󰁺 {capacity}%",
    "warning": 20,
    "critical": 10,
    "interval": 1
  },
  "wireplumber": {
    "format": "󰕾 {volume}%",
    "format-muted": "󰖁 0%"
  },
  "network": {
    "format-wifi": "󰤨  {essid}",
    "format-disconnected": "✗",
    "tooltip": false,
    "on-click": "nm-connection-editor"
  },
  "custom/notification": {
    "format": "󰂚",
    "on-click": "swaync-client -t",
    "tooltip": false
  },
  "custom/clipboard": {
    "format": "󰅇 Clipboard",
    "on-click": "cliphist list | wofi --dmenu | cliphist decode | wl-copy",
    "on-click-right": "cliphist wipe",
    "tooltip": false
  },
  "hyprland/language": {
    "format": "⌨ {}",
    "tooltip": false
}
}
